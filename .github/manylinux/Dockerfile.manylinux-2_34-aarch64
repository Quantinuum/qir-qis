FROM quay.io/pypa/manylinux_2_34_aarch64@sha256:c4ef6b53c536ab5ac10700d2ea43653a2dd00e2a81f04d7db8488b8ba1fc1aca

ARG LLVM_VERSION=21.1.8
ENV LLVM_CONFIG_STRIP_CFLAGS=1
ARG LLVM_RPM_REPO=https://download.copr.fedorainfracloud.org/results/%40fedora-llvm-team/llvm-snapshots-big-merge-20250710/centos-stream-9-aarch64/09261470-llvm

RUN dnf install -y \
    curl \
    xz \
    libffi-devel \
    zlib-devel \
    libzstd-devel \
    libxml2-devel \
    ncurses-compat-libs \
    ncurses-devel \
    python3 && \
    dnf clean all

RUN printf '%s\n' \
    '[llvm21-arm]' \
    'name=LLVM 21 ARM RPM snapshot' \
    "baseurl=${LLVM_RPM_REPO}" \
    'enabled=1' \
    'gpgcheck=0' \
    >/etc/yum.repos.d/llvm21-arm.repo && \
    dnf makecache --refresh && \
    dnf install -y \
      clang \
      llvm \
      llvm-devel \
      llvm-static \
      lld && \
    llvm-config --version | grep -E '^21\.' && \
    ! llvm-config --libnames --link-static | grep -q 'Polly' && \
    mkdir -p /opt && \
    ln -s "$(llvm-config --prefix)" /opt/llvm && \
    dnf clean all

COPY .github/manylinux/llvm-config-wrapper.sh /tmp/llvm-config-wrapper.sh
RUN mv /opt/llvm/bin/llvm-config /opt/llvm/bin/llvm-config.real && \
    install -m 0755 /tmp/llvm-config-wrapper.sh /opt/llvm/bin/llvm-config && \
    rm -f /tmp/llvm-config-wrapper.sh
