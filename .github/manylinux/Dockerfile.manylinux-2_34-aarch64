FROM quay.io/pypa/manylinux_2_34_aarch64@sha256:c4ef6b53c536ab5ac10700d2ea43653a2dd00e2a81f04d7db8488b8ba1fc1aca

ARG LLVM_VERSION=21.1.8
ENV LLVM_CONFIG_STRIP_CFLAGS=1
ARG LLVM_RPM_BASE=https://download.copr.fedorainfracloud.org/results/%40fedora-llvm-team/llvm-snapshots-big-merge-20250710/centos-stream-9-aarch64/09261470-llvm

RUN dnf install -y \
    curl \
    xz \
    libffi-devel \
    zlib-devel \
    libzstd-devel \
    libxml2-devel \
    ncurses-compat-libs \
    ncurses-devel \
    python3 && \
    dnf clean all

RUN dnf install -y \
      "${LLVM_RPM_BASE}/llvm-filesystem-21.0.0~pre20250710.ge8a50a2568bf7c-1.el9.aarch64.rpm" \
      "${LLVM_RPM_BASE}/llvm-libs-21.0.0~pre20250710.ge8a50a2568bf7c-1.el9.aarch64.rpm" \
      "${LLVM_RPM_BASE}/llvm-21.0.0~pre20250710.ge8a50a2568bf7c-1.el9.aarch64.rpm" \
      "${LLVM_RPM_BASE}/llvm-devel-21.0.0~pre20250710.ge8a50a2568bf7c-1.el9.aarch64.rpm" \
      "${LLVM_RPM_BASE}/llvm-static-21.0.0~pre20250710.ge8a50a2568bf7c-1.el9.aarch64.rpm" \
      "${LLVM_RPM_BASE}/clang-libs-21.0.0~pre20250710.ge8a50a2568bf7c-1.el9.aarch64.rpm" \
      "${LLVM_RPM_BASE}/clang-resource-filesystem-21.0.0~pre20250710.ge8a50a2568bf7c-1.el9.aarch64.rpm" \
      "${LLVM_RPM_BASE}/clang-21.0.0~pre20250710.ge8a50a2568bf7c-1.el9.aarch64.rpm" \
      "${LLVM_RPM_BASE}/lld-libs-21.0.0~pre20250710.ge8a50a2568bf7c-1.el9.aarch64.rpm" \
      "${LLVM_RPM_BASE}/lld-21.0.0~pre20250710.ge8a50a2568bf7c-1.el9.aarch64.rpm" && \
    llvm-config --version | grep -E '^21\.' && \
    ! llvm-config --libnames --link-static | grep -q 'Polly' && \
    mkdir -p /opt && \
    ln -s "$(llvm-config --prefix)" /opt/llvm && \
    dnf clean all

COPY .github/manylinux/llvm-config-wrapper.sh /tmp/llvm-config-wrapper.sh
RUN mv /opt/llvm/bin/llvm-config /opt/llvm/bin/llvm-config.real && \
    install -m 0755 /tmp/llvm-config-wrapper.sh /opt/llvm/bin/llvm-config && \
    rm -f /tmp/llvm-config-wrapper.sh
