FROM quay.io/pypa/manylinux_2_34_aarch64@sha256:c4ef6b53c536ab5ac10700d2ea43653a2dd00e2a81f04d7db8488b8ba1fc1aca

ARG LLVM_VERSION=21.1.8
ENV LLVM_CONFIG_STRIP_CFLAGS=1

RUN dnf install -y \
    curl \
    gettext \
    jq \
    xz \
    libffi-devel \
    zlib-devel \
    libzstd-devel \
    libxml2-devel \
    ncurses-compat-libs \
    ncurses-devel \
    python3 && \
    dnf install -y --skip-broken 'dnf-command(copr)' 'dnf5-command(copr)' && \
    dnf clean all

RUN dnf -y copr enable @fedora-llvm-team/llvm-snapshots && \
    repo_file=$(dnf repoinfo --json '*llvm-snapshots*' | jq -r '.[0].repo_file_path') && \
    distname=$(rpm --eval '%{?fedora:fedora}%{?rhel:rhel}') && \
    envsubst '$distname' < "${repo_file}" > /tmp/llvm-snapshots.repo && \
    cat /tmp/llvm-snapshots.repo > "${repo_file}" && \
    dnf install -y \
      clang \
      llvm \
      llvm-devel \
      llvm-static \
      lld \
      polly-devel && \
    mkdir -p /opt && \
    ln -s "$(llvm-config --prefix)" /opt/llvm && \
    dnf clean all && \
    rm -f /tmp/llvm-snapshots.repo

COPY .github/manylinux/llvm-config-wrapper.sh /tmp/llvm-config-wrapper.sh
RUN mv /opt/llvm/bin/llvm-config /opt/llvm/bin/llvm-config.real && \
    install -m 0755 /tmp/llvm-config-wrapper.sh /opt/llvm/bin/llvm-config && \
    rm -f /tmp/llvm-config-wrapper.sh
