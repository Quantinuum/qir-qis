  %barrier_qubits = alloca [2 x i64], align 16
  %0 = load <2 x i64>, ptr @qis_qs, align 16
  store <2 x i64> %0, ptr %barrier_qubits, align 16
  call void @___barrier(ptr nonnull %barrier_qubits, i64 2)
  %qbit.i.i17 = load i64, ptr getelementptr inbounds nuw (i8, ptr @qis_qs, i64 8), align 8
  call void @___rxy(i64 %qbit.i.i17, double 0xBFF921FB54442D18, double 0x3FF921FB54442D18)
  %qbit.i8.i = load i64, ptr @qis_qs, align 16
  %qbit.i11.i = load i64, ptr getelementptr inbounds nuw (i8, ptr @qis_qs, i64 8), align 8
  call void @___rzz(i64 %qbit.i8.i, i64 %qbit.i11.i, double 0x3FF921FB54442D18)
  %qbit.i14.i = load i64, ptr @qis_qs, align 16
  call void @___rz(i64 %qbit.i14.i, double 0xBFF921FB54442D18)
  %qbit.i17.i = load i64, ptr getelementptr inbounds nuw (i8, ptr @qis_qs, i64 8), align 8
  call void @___rxy(i64 %qbit.i17.i, double 0x3FF921FB54442D18, double 0x400921FB54442D18)
  %qbit.i20.i = load i64, ptr getelementptr inbounds nuw (i8, ptr @qis_qs, i64 8), align 8
  call void @___rz(i64 %qbit.i20.i, double 0xBFF921FB54442D18)
  %barrier_qubits2 = alloca [1 x i64], align 8
  %qbit.i18 = load i64, ptr @qis_qs, align 16
  store i64 %qbit.i18, ptr %barrier_qubits2, align 8
  call void @___barrier(ptr nonnull %barrier_qubits2, i64 1)
  %qbit5 = load i64, ptr @qis_qs, align 16
  %meas = call i64 @___lazy_measure(i64 %qbit5)
  %qbit6 = load i64, ptr getelementptr inbounds nuw (i8, ptr @qis_qs, i64 8), align 8
  %meas7 = call i64 @___lazy_measure(i64 %qbit6)
  call void @print_int(ptr nonnull @res_t0.1, i64 16, i64 2)
  %bool = call i1 @___read_future_bool(i64 %meas)
  call void @___dec_future_refcount(i64 %meas)
  call void @print_bool(ptr nonnull @res_r1, i64 14, i1 %bool)
  %bool8 = call i1 @___read_future_bool(i64 %meas7)
  call void @___dec_future_refcount(i64 %meas7)
  call void @print_bool(ptr nonnull @res_r2, i64 14, i1 %bool8)
  %qbit9 = load i64, ptr @qis_qs, align 16
  call void @___qfree(i64 %qbit9)
  %qbit10 = load i64, ptr getelementptr inbounds nuw (i8, ptr @qis_qs, i64 8), align 8
